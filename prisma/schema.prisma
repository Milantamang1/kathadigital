generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BookingStatus {
  NEW
  CONTACTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum MessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum EventStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         String   @default("admin")
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BookingInquiry {
  id        String        @id @default(cuid())
  name      String
  email     String?
  phone     String
  service   String?
  eventDate DateTime?
  location  String?
  budget    String?
  message   String?
  status    BookingStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    MessageStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Service {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  short            String?
  shortDescription String?
  fullDescription  String?
  image            String?
  imageUrl         String?
  position         String?
  status           ContentStatus @default(DRAFT)
  featured         Boolean       @default(false)
  displayOrder     Int           @default(0)
  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model PortfolioProject {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  category     String
  clientName   String?
  eventDate    DateTime?
  dateLabel    String?
  location     String?
  desc         String?
  description  String?
  image        String?
  imageUrl     String?
  position     String?
  videoUrl     String?
  status       ContentStatus @default(DRAFT)
  featured     Boolean       @default(false)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Production {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  type         String?
  desc         String?
  description  String?
  image        String?
  imageUrl     String?
  position     String?
  youtubeId    String?
  subscribeUrl String?
  destinations Json?
  videoUrl     String?
  episodes     Json?
  status       ContentStatus @default(DRAFT)
  featured     Boolean       @default(false)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model NewsPost {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  category     String?
  author       String?
  dateLabel    String?
  excerpt      String?
  content      String?
  image        String?
  imageUrl     String?
  position     String?
  status       ContentStatus @default(DRAFT)
  featured     Boolean       @default(false)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Event {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  type          String?
  date          DateTime?
  dateLabel     String?
  location      String?
  desc          String?
  description   String?
  image         String?
  imageUrl      String?
  position      String?
  status        EventStatus   @default(UPCOMING)
  contentStatus ContentStatus @default(PUBLISHED)
  featured      Boolean       @default(false)
  displayOrder  Int           @default(0)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeContent {
  id                  String        @id @default("home")
  metadata            Json
  heroImg             String
  heroAlt             String
  eyebrow             String
  title               String
  subtitle            String
  actions             Json
  sideLabel           String
  metrics             Json
  whoWeAre            Json
  servicesSection     Json
  selectedWorkSection Json
  productionsSection  Json
  youtubeSection      Json
  newsSection         Json
  testimonialsSection Json
  cta                 Json
  hiddenImage         Json
  sections            Json
  status              ContentStatus @default(PUBLISHED)
  publishedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model AboutContent {
  id          String        @id @default("about")
  metadata    Json
  hero        Json
  studio      Json
  principles  Json
  founder     Json
  team        Json
  cta         Json
  sections    Json
  status      ContentStatus @default(PUBLISHED)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PageContent {
  id           String        @id @default(cuid())
  page         String
  section      String
  key          String
  value        Json
  status       ContentStatus @default(PUBLISHED)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([page, section, key])
}

model Testimonial {
  id           String        @id @default(cuid())
  name         String
  role         String
  quote        String
  status       ContentStatus @default(PUBLISHED)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([name, role])
}

model TeamMember {
  id           String        @id @default(cuid())
  name         String
  role         String
  note         String?
  image        String?
  position     String?
  status       ContentStatus @default(PUBLISHED)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([name, role])
}

model Principle {
  id           String        @id @default(cuid())
  eyebrow      String
  title        String
  text         String
  iconKey      String?
  status       ContentStatus @default(PUBLISHED)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([eyebrow, title])
}

model VideoItem {
  id           String        @id @default(cuid())
  section      String
  youtubeId    String
  title        String
  type         String?
  description  String?
  status       ContentStatus @default(PUBLISHED)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([section, youtubeId])
}

model CategoryOption {
  id           String        @id @default(cuid())
  scope        String
  label        String
  status       ContentStatus @default(PUBLISHED)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([scope, label])
}

model NavigationItem {
  id           String        @id @default(cuid())
  label        String
  to           String
  status       ContentStatus @default(PUBLISHED)
  displayOrder Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([label, to])
}
